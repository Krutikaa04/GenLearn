# Application
PORT=8000
ENVIRONMENT=development

# AI Provider (get free key at https://aistudio.google.com)
GEMINI_API_KEY=your-gemini-api-key
MODEL_NAME=gemini-1.5-flash
EMBEDDING_MODEL=models/text-embedding-004

# MongoDB (for Atlas Vector Search)
MONGODB_URI=mongodb://admin:password@mongodb:27017/genlearn?authSource=admin

# Internal Security (must match INTERNAL_API_KEY in backend .env)
INTERNAL_API_KEY=your-internal-api-key-shared-with-ai-service

# Backend URL (for CORS)
BACKEND_URL=http://backend:3000

# Redis
REDIS_URL=redis://redis:6379

# Adaptive intelligence rollout flags (default off — existing behavior unchanged)
RAG_GENERATION_ENABLED=false
