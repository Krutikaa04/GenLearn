# Backend API origin (without the /api/v1 suffix — the app appends it).
# Local: http://localhost:3000
# Production: the Render backend URL, e.g. https://genlearn-backend.onrender.com
VITE_API_URL=http://localhost:3000

# Behavior telemetry (default off — quiz experience unchanged when disabled)
VITE_BEHAVIOR_TELEMETRY_ENABLED=false
