# Application
# In production (Render) set NODE_ENV=production. PORT is injected by the
# platform at runtime — do not hardcode it there; this default is for local dev.
NODE_ENV=development
PORT=3000

# Database
# Local: docker-compose Mongo. Production: MongoDB Atlas SRV connection string,
# e.g. mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/<db>?retryWrites=true
DATABASE_URL=mongodb://admin:password@mongodb:27017/genlearn?authSource=admin

# Redis
# Local: docker-compose Redis. Production: managed Redis URL (rediss:// if TLS).
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-minimum-64-characters-change-this-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# AI Platform
AI_SERVICE_URL=http://ai-service:8000
INTERNAL_API_KEY=your-internal-api-key-shared-with-ai-service

# Email (use Mailtrap for development: https://mailtrap.io)
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your-mailtrap-user
SMTP_PASSWORD=your-mailtrap-password
SMTP_FROM=noreply@genlearn.dev

# Frontend URL — canonical frontend origin, used for email links and CORS.
# Production: the Vercel production URL, e.g. https://genlearn.vercel.app
FRONTEND_URL=http://localhost:5173

# CORS — additional allowed browser origins as a comma-separated list.
# FRONTEND_URL is always allowed; use this for staging/extra frontends.
# CORS_ORIGINS=https://genlearn.vercel.app,https://staging.genlearn.vercel.app
# Set to true to allow Vercel preview deployments (https://<hash>.vercel.app):
ALLOW_VERCEL_PREVIEWS=false

# Adaptive intelligence rollout flags (all default off — existing behavior unchanged)
BEHAVIOR_TELEMETRY_ENABLED=false
ADAPTIVE_LEARNING_ENABLED=false
RAG_GENERATION_ENABLED=false
ADAPTIVE_QUIZ_GENERATION_ENABLED=false
ADAPTIVE_LESSON_GENERATION_ENABLED=false
